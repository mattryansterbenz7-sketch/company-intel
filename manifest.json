{
  "manifest_version": 3,
  "name": "Coop.ai",
  "version": "1.0",
  "description": "Your job search, with context. Coop is your AI advisor with full memory across everything.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "storage",
    "unlimitedStorage",
    "identity"
  ],
  "oauth2": {
    "client_id": "221085528448-0arlbjv4uudl9m1ad5oatrp7ufn5eaj9.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/contacts.other.readonly",
      "https://www.googleapis.com/auth/contacts.readonly"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["coop.js", "content.js", "coop-assist.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Coop.ai",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html", "sidepanel.js", "chat.js"],
      "matches": ["<all_urls>"]
    }
  ]
}